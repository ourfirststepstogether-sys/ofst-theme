{% comment %}
  OFST wordmark logo — renders in color (default) or white variant.
  Usage:  {% render 'ofst-logo' %}
          {% render 'ofst-logo', variant: 'white' %}
  The footprint SVG is derived from the uploaded logo asset.
{% endcomment %}

{% assign is_white = false %}
{% if variant == 'white' %}{% assign is_white = true %}{% endif %}

{% if is_white %}
  {% assign c_o     = '#FFFFFF' %}
  {% assign c_first = '#FFFFFF' %}
  {% assign c_s     = '#FFFFFF' %}
  {% assign c_teps  = '#FFFFFF' %}
  {% assign c_foot  = '#FFFFFF' %}
{% else %}
  {% assign c_o     = '#7EC8D8' %}
  {% assign c_first = '#FF6A6A' %}
  {% assign c_s     = '#FF6A6A' %}
  {% assign c_teps  = '#FFCC5C' %}
  {% assign c_foot  = '#FF6A6A' %}
{% endif %}

<span class="ofst-logo" aria-label="Our First Steps" style="display:inline-flex;align-items:center;gap:0;font-family:'Fredoka','Bubblegum Sans','Comic Sans MS',system-ui,sans-serif;font-weight:700;font-size:{{ size | default: 26 }}px;letter-spacing:-.01em;line-height:1;text-decoration:none;">
  <span style="color:{{ c_o }}">O</span><span style="color:{{ c_o }}">ur</span>
  <span style="color:{{ c_first }};margin-left:.12em">Fir</span>
  <span style="color:{{ c_s }};position:relative;display:inline-flex;align-items:flex-end">
    <span>S</span>
    <svg width="{{ size | default: 26 | times: 0.45 | round }}" height="{{ size | default: 26 | times: 0.45 | round }}" viewBox="0 0 20 20" style="position:absolute;top:-.12em;left:-.05em" aria-hidden="true">
      <ellipse cx="10" cy="13" rx="4.5" ry="5.5" fill="{{ c_foot }}"/>
      <circle cx="6"    cy="5"   r="1.6" fill="{{ c_foot }}"/>
      <circle cx="9"    cy="3"   r="1.5" fill="{{ c_foot }}"/>
      <circle cx="12.5" cy="3.5" r="1.4" fill="{{ c_foot }}"/>
      <circle cx="15.5" cy="5.5" r="1.3" fill="{{ c_foot }}"/>
    </svg>
  </span>
  <span style="color:{{ c_teps }}">teps</span>
</span>
