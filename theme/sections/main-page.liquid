<section class="ofst-section" id="ofst-page-{{ section.id }}">
  <div class="ofst-container">
    <h1 class="ofst-h1">{{ page.title | escape }}</h1>
    <div class="ofst-rte">{{ page.content }}</div>
  </div>
</section>

<style>
  #ofst-page-{{ section.id }} { padding: 48px 0 80px; }
  #ofst-page-{{ section.id }} .ofst-rte { margin-top: 24px; max-width: 68ch; font-family: var(--ofst-font-body); font-size: 1.0625rem; line-height: 1.7; }
  #ofst-page-{{ section.id }} .ofst-rte p { margin: 0 0 1em; }
  #ofst-page-{{ section.id }} .ofst-rte h2 { font-family: var(--ofst-font-display); font-size: 1.75rem; margin: 1.6em 0 .4em; }
  #ofst-page-{{ section.id }} .ofst-rte h3 { font-family: var(--ofst-font-display); font-size: 1.25rem; margin: 1.4em 0 .3em; }
  #ofst-page-{{ section.id }} .ofst-rte a { color: var(--ofst-coral); }
</style>

{% schema %}
{
  "name": "Page content",
  "settings": [],
  "presets": [{ "name": "Page content" }]
}
{% endschema %}
