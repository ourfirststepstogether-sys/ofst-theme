<section class="ofst-section" id="ofst-404-{{ section.id }}">
  <div class="ofst-container">
    <div class="ofst-404">
      <div class="ofst-404__badge">404</div>
      <h1 class="ofst-h1">{{ 'general.404.title' | t }}</h1>
      <p class="ofst-body">{{ 'general.404.subtext' | t }}</p>
      <a href="{{ routes.root_url }}" class="ofst-btn ofst-btn-cta">{{ 'general.404.link' | t }}</a>
    </div>
  </div>
</section>

<style>
  #ofst-404-{{ section.id }} { padding: 80px 0 120px; }
  #ofst-404-{{ section.id }} .ofst-404 { text-align: center; max-width: 560px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 16px; }
  #ofst-404-{{ section.id }} .ofst-404__badge { display: inline-block; font-family: var(--ofst-font-display); font-weight: 700; font-size: 4rem; color: var(--ofst-coral); line-height: 1; }
</style>

{% schema %}
{
  "name": "404",
  "settings": [],
  "presets": [{ "name": "404" }]
}
{% endschema %}
