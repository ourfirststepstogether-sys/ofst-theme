<section class="ofst-section" id="ofst-password-{{ section.id }}">
  <div class="ofst-container">
    <div class="ofst-password">
      <span class="ofst-eyebrow">{{ 'general.password_page.opening_soon' | t }}</span>
      <h1 class="ofst-display">{{ shop.name }}</h1>
      {% if shop.password_message != blank %}
        <div class="ofst-rte">{{ shop.password_message }}</div>
      {% endif %}

      <div class="ofst-password__card">
        <h2 class="ofst-h3">{{ 'general.password_page.signup_form_heading' | t }}</h2>
        {% form 'customer' %}
          {% if form.posted_successfully? %}
            <p class="ofst-success">{{ 'general.password_page.signup_form_success' | t }}</p>
          {% endif %}
          <input type="hidden" name="contact[tags]" value="prospect,password page">
          <div class="ofst-password__field">
            <input type="email" name="contact[email]" placeholder="{{ 'general.password_page.signup_form_email_placeholder' | t }}" required>
            <button type="submit" class="ofst-btn ofst-btn-cta">{{ 'general.password_page.signup_form_submit' | t }}</button>
          </div>
        {% endform %}
      </div>

      <details class="ofst-password__login">
        <summary>{{ 'general.password_page.login_form_heading' | t }}</summary>
        {% form 'storefront_password' %}
          {% if form.errors %}<p class="ofst-error">{{ 'general.password_page.login_form_error' | t }}</p>{% endif %}
          <input type="password" name="password" placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}" required>
          <button type="submit" class="ofst-btn ofst-btn-outline">{{ 'general.password_page.login_form_submit' | t }}</button>
        {% endform %}
      </details>

      <p class="ofst-muted">{{ 'general.password_page.admin_link_html' | t }}</p>
    </div>
  </div>
</section>

<style>
  #ofst-password-{{ section.id }} { padding: 80px 0; background: var(--ofst-bg); }
  #ofst-password-{{ section.id }} .ofst-password { max-width: 560px; margin: 0 auto; text-align: center; display: flex; flex-direction: column; gap: 16px; align-items: center; }
  #ofst-password-{{ section.id }} .ofst-password__card { width: 100%; background: #FFF3D1; border: 1px solid var(--ofst-ink); border-radius: 18px; padding: 24px; margin-top: 16px; }
  #ofst-password-{{ section.id }} .ofst-password__field { display: flex; gap: 8px; margin-top: 12px; }
  #ofst-password-{{ section.id }} .ofst-password__field input { flex: 1; padding: 12px 16px; border: 2px solid var(--ofst-ink); border-radius: 999px; }
  #ofst-password-{{ section.id }} .ofst-password__login { margin-top: 8px; }
  #ofst-password-{{ section.id }} .ofst-password__login summary { cursor: pointer; font-family: var(--ofst-font-display); font-weight: 600; padding: 8px; }
  #ofst-password-{{ section.id }} .ofst-password__login input { display: block; padding: 10px 14px; border: 2px solid var(--ofst-ink); border-radius: 999px; margin: 8px auto; }
</style>

{% schema %}
{
  "name": "Password",
  "settings": [],
  "presets": [{ "name": "Password" }]
}
{% endschema %}
