{% comment %} OFST Real Parent Moments — Section 5 of 8 on the homepage {% endcomment %}


<section id="ofst-tmn-{{ section.id }}" class="ofst-section ofst-testimonials">
  <div class="ofst-container">
    <div class="ofst-tmn__header">
      <span class="ofst-eyebrow" style="color:var(--ofst-coral)">{{ section.settings.eyebrow | default: 'Real parent moments 💖' }}</span>
      <h2 class="ofst-h1 ofst-tmn__heading">{{ section.settings.heading | default: 'Not reviews. Just honest notes from fellow parents.' | escape }}</h2>
    </div>

    <div class="ofst-tmn__grid">
      {% for block in section.blocks %}
        <figure class="ofst-card ofst-tmn__card" {{ block.shopify_attributes }}>
          <div class="ofst-tmn__stars" aria-label="5 stars">
            {% for s in (1..5) %}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#FFB629" stroke="none" aria-hidden="true"><path d="M12 3l2.6 5.5 6 .6-4.5 4 1.3 6L12 16l-5.4 3.1 1.3-6-4.5-4 6-.6z"/></svg>
            {% endfor %}
          </div>
          <blockquote class="ofst-tmn__quote">{{ block.settings.quote | escape }}</blockquote>
          <figcaption class="ofst-tmn__caption">
            <div class="ofst-tmn__avatar" aria-hidden="true">{{ block.settings.author | slice: 0 | upcase }}</div>
            <div>
              <div class="ofst-tmn__author">{{ block.settings.author | escape }}</div>
              {% if block.settings.location != blank %}
                <div class="ofst-tmn__location">{{ block.settings.location | escape }}</div>
              {% endif %}
            </div>
          </figcaption>
        </figure>
      {% endfor %}

      {% comment %} Fallback quotes {% endcomment %}
      {% if section.blocks.size == 0 %}
        {% assign fallback_quotes = '"I bought it skeptical. My 3yo is still building things with it six months later. It\'s the toy we\'ve kept.",Sana mom of one,Austin TX|"It got both kids to play side-by-side instead of fighting. I don\'t know what witchcraft this is.",Derek & Pri,Portland OR|"Honestly? I use the phone book cover more than she does. No shame.",Lauren mom of two,Columbus OH' | split: "|" %}
        {% for fq in fallback_quotes %}
          {% assign fq_parts = fq | split: "," %}
          <figure class="ofst-card ofst-tmn__card">
            <div class="ofst-tmn__stars" aria-label="5 stars">
              {% for s in (1..5) %}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#FFB629" stroke="none" aria-hidden="true"><path d="M12 3l2.6 5.5 6 .6-4.5 4 1.3 6L12 16l-5.4 3.1 1.3-6-4.5-4 6-.6z"/></svg>
              {% endfor %}
            </div>
            <blockquote class="ofst-tmn__quote">{{ fq_parts[0] }}</blockquote>
            <figcaption class="ofst-tmn__caption">
              <div class="ofst-tmn__avatar" aria-hidden="true">{{ fq_parts[1] | slice: 0 | upcase }}</div>
              <div>
                <div class="ofst-tmn__author">{{ fq_parts[1] }}</div>
                <div class="ofst-tmn__location">{{ fq_parts[2] }}</div>
              </div>
            </figcaption>
          </figure>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<style>
  #ofst-tmn-{{ section.id }} {
    padding: 96px 0;
    background: var(--ofst-bg-alt);
  }
  #ofst-tmn-{{ section.id }} .ofst-tmn__header {
    text-align: center;
    margin-bottom: 40px;
  }
  #ofst-tmn-{{ section.id }} .ofst-tmn__heading { margin-top: 10px; font-size: clamp(24px,3vw,40px); }
  #ofst-tmn-{{ section.id }} .ofst-tmn__grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 20px;
  }
  #ofst-tmn-{{ section.id }} .ofst-tmn__card { padding: 28px; }
  #ofst-tmn-{{ section.id }} .ofst-tmn__stars { display: flex; gap: 2px; margin-bottom: 10px; }
  #ofst-tmn-{{ section.id }} .ofst-tmn__quote {
    font-size: 17px;
    line-height: 1.55;
    color: var(--ofst-deep);
    font-weight: 500;
    margin: 0;
  }
  #ofst-tmn-{{ section.id }} .ofst-tmn__caption {
    margin-top: 18px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  #ofst-tmn-{{ section.id }} .ofst-tmn__avatar {
    width: 36px; height: 36px;
    border-radius: 18px;
    background: var(--ofst-teal);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
    font-family: var(--ofst-font-display);
  }
  #ofst-tmn-{{ section.id }} .ofst-tmn__author   { font-size: 13px; font-weight: 600; color: #000; }
  #ofst-tmn-{{ section.id }} .ofst-tmn__location { font-size: 12px; color: var(--ofst-mid); margin-top: 2px; }

  @media (max-width: 900px) {
    #ofst-tmn-{{ section.id }} .ofst-tmn__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    #ofst-tmn-{{ section.id }} { padding: 56px 0; }
    #ofst-tmn-{{ section.id }} .ofst-tmn__grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "OFST Real Parent Moments",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real parent moments 💖" },
    { "type": "text", "id": "heading", "label": "Heading",  "default": "Not reviews. Just honest notes from fellow parents." }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote",    "label": "Quote",    "default": "\"I bought it skeptical. My 3yo is still building things with it six months later. It's the toy we've kept.\"" },
        { "type": "text",     "id": "author",   "label": "Author",   "default": "Sana, mom of one" },
        { "type": "text",     "id": "location", "label": "Location", "default": "Austin, TX" }
      ]
    }
  ],
  "presets": [{ "name": "OFST Real Parent Moments" }]
}
{% endschema %}
