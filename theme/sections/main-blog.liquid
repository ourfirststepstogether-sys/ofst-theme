<section class="ofst-section" id="ofst-blog-{{ section.id }}">
  <div class="ofst-container">
    <header class="ofst-blog-head">
      <span class="ofst-eyebrow">Journal</span>
      <h1 class="ofst-h1">{{ blog.title | escape }}</h1>
    </header>

    {% paginate blog.articles by 9 %}
      <div class="ofst-blog-grid">
        {% for article in blog.articles %}
          <article class="ofst-article-card">
            <a href="{{ article.url }}" class="ofst-article-card__link">
              {% if article.image %}
                <div class="ofst-article-card__media">
                  <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.image.alt | escape }}" loading="lazy">
                </div>
              {% else %}
                <div class="ofst-article-card__media ofst-article-card__media--empty"></div>
              {% endif %}
              <div class="ofst-article-card__body">
                {% if article.tags.size > 0 %}
                  <span class="ofst-chip ofst-chip-coral">{{ article.tags.first }}</span>
                {% endif %}
                <h2 class="ofst-h3">{{ article.title }}</h2>
                <p class="ofst-body">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
                <span class="ofst-muted">{{ article.published_at | date: "%B %-d, %Y" }}</span>
              </div>
            </a>
          </article>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="ofst-pagination" aria-label="pagination">
          {% if paginate.previous %}<a href="{{ paginate.previous.url }}" class="ofst-link">&larr; {{ 'general.pagination.previous' | t }}</a>{% endif %}
          {% if paginate.next %}<a href="{{ paginate.next.url }}" class="ofst-link">{{ 'general.pagination.next' | t }} &rarr;</a>{% endif %}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

<style>
  #ofst-blog-{{ section.id }} { padding: 48px 0 80px; }
  #ofst-blog-{{ section.id }} .ofst-blog-head { text-align: center; margin-bottom: 32px; }
  #ofst-blog-{{ section.id }} .ofst-blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  #ofst-blog-{{ section.id }} .ofst-article-card__link { display: block; text-decoration: none; color: inherit; border: 1px solid var(--ofst-base); border-radius: 18px; overflow: hidden; background: #fff; transition: transform .15s ease; }
  #ofst-blog-{{ section.id }} .ofst-article-card__link:hover { transform: translateY(-2px); }
  #ofst-blog-{{ section.id }} .ofst-article-card__media { aspect-ratio: 4/3; overflow: hidden; background: var(--ofst-base); }
  #ofst-blog-{{ section.id }} .ofst-article-card__media img { width: 100%; height: 100%; object-fit: cover; }
  #ofst-blog-{{ section.id }} .ofst-article-card__body { padding: 16px 18px 20px; display: flex; flex-direction: column; gap: 8px; }
  #ofst-blog-{{ section.id }} .ofst-pagination { display: flex; justify-content: center; gap: 24px; margin-top: 40px; }
  @media (max-width: 900px) { #ofst-blog-{{ section.id }} .ofst-blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { #ofst-blog-{{ section.id }} .ofst-blog-grid { grid-template-columns: 1fr; } }
</style>

{% schema %}
{
  "name": "Blog",
  "settings": [],
  "presets": [{ "name": "Blog" }]
}
{% endschema %}
