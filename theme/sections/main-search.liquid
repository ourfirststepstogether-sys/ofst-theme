<section class="ofst-section" id="ofst-search-{{ section.id }}">
  <div class="ofst-container">
    <header class="ofst-search-head">
      <h1 class="ofst-h1">{{ 'general.search.placeholder' | t }}</h1>
      <form action="{{ routes.search_url }}" method="get" class="ofst-search-form">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" aria-label="{{ 'general.search.placeholder' | t }}" class="ofst-search-input">
        <button type="submit" class="ofst-btn ofst-btn-cta">{{ 'general.search.submit' | t }}</button>
      </form>
    </header>

    {% if search.performed %}
      {% if search.results_count > 0 %}
        <p class="ofst-muted">{{ 'general.search.results_with_count' | t: count: search.results_count, terms: search.terms }}</p>
        {% paginate search.results by 12 %}
          <div class="ofst-search-grid">
            {% for item in search.results %}
              <a href="{{ item.url }}" class="ofst-search-card">
                {% if item.featured_image %}
                  <div class="ofst-search-card__media"><img src="{{ item.featured_image | image_url: width: 600 }}" alt="{{ item.title | escape }}" loading="lazy"></div>
                {% elsif item.image %}
                  <div class="ofst-search-card__media"><img src="{{ item.image | image_url: width: 600 }}" alt="{{ item.title | escape }}" loading="lazy"></div>
                {% endif %}
                <div class="ofst-search-card__body">
                  <h3 class="ofst-h3">{{ item.title }}</h3>
                  {% if item.object_type == 'product' %}<p class="ofst-body">{{ item.price | money }}</p>{% endif %}
                </div>
              </a>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav class="ofst-pagination" aria-label="pagination">
              {% if paginate.previous %}<a href="{{ paginate.previous.url }}" class="ofst-link">&larr; {{ 'general.pagination.previous' | t }}</a>{% endif %}
              {% if paginate.next %}<a href="{{ paginate.next.url }}" class="ofst-link">{{ 'general.pagination.next' | t }} &rarr;</a>{% endif %}
            </nav>
          {% endif %}
        {% endpaginate %}
      {% else %}
        <p class="ofst-body">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
      {% endif %}
    {% endif %}
  </div>
</section>

<style>
  #ofst-search-{{ section.id }} { padding: 48px 0 80px; }
  #ofst-search-{{ section.id }} .ofst-search-head { text-align: center; margin-bottom: 32px; }
  #ofst-search-{{ section.id }} .ofst-search-form { display: flex; gap: 8px; max-width: 520px; margin: 16px auto 0; }
  #ofst-search-{{ section.id }} .ofst-search-input { flex: 1; padding: 12px 16px; border: 2px solid var(--ofst-ink); border-radius: 999px; font-family: var(--ofst-font-body); }
  #ofst-search-{{ section.id }} .ofst-search-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 24px; }
  #ofst-search-{{ section.id }} .ofst-search-card { display: block; text-decoration: none; color: inherit; border: 1px solid var(--ofst-base); border-radius: 16px; overflow: hidden; background: #fff; }
  #ofst-search-{{ section.id }} .ofst-search-card__media { aspect-ratio: 1/1; background: var(--ofst-base); }
  #ofst-search-{{ section.id }} .ofst-search-card__media img { width: 100%; height: 100%; object-fit: cover; }
  #ofst-search-{{ section.id }} .ofst-search-card__body { padding: 12px 14px 16px; }
  #ofst-search-{{ section.id }} .ofst-pagination { display: flex; justify-content: center; gap: 24px; margin-top: 32px; }
  @media (max-width: 900px) { #ofst-search-{{ section.id }} .ofst-search-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

{% schema %}
{
  "name": "Search",
  "settings": [],
  "presets": [{ "name": "Search" }]
}
{% endschema %}
