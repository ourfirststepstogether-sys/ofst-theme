{% comment %} OFST Shop by Category — Section 4 of 8 on the homepage {% endcomment %}

<link rel="stylesheet" href="{{ 'ofst-theme.css' | asset_url }}">

<section id="ofst-cat-{{ section.id }}" class="ofst-section ofst-categories">
  <div class="ofst-container">
    <div class="ofst-cat__header">
      <span class="ofst-eyebrow">{{ section.settings.eyebrow | default: 'Shop by category 🛍️' }}</span>
      <h2 class="ofst-h1 ofst-cat__heading">{{ section.settings.heading | default: 'Find what fits your kid today.' | escape }}</h2>
    </div>

    <div class="ofst-cat__grid">
      {% for block in section.blocks %}
        {% assign wide = forloop.first %}
        <a href="{{ block.settings.collection_url | default: '#' }}"
           class="ofst-cat__card {% if wide %}ofst-cat__card--wide{% endif %}"
           style="background:{% if block.settings.tone == 'teal' %}#CDE6ED{% elsif block.settings.tone == 'yellow' %}#FFE9B8{% else %}#FFD8D8{% endif %}"
           {{ block.shopify_attributes }}>

          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'ofst-cat__bg-img', alt: block.settings.image.alt | escape }}
            <div class="ofst-cat__overlay" aria-hidden="true"></div>
          {% endif %}

          <div class="ofst-cat__content {% if block.settings.image != blank %}ofst-cat__content--on-img{% endif %}">
            <h3 class="ofst-cat__title">{{ block.settings.title | escape }}</h3>
            <p class="ofst-cat__sub">{{ block.settings.subtitle | escape }}</p>
            <span class="ofst-cat__cta">
              Shop collection
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </div>
        </a>
      {% endfor %}

      {% comment %} Fallback when no blocks configured {% endcomment %}
      {% if section.blocks.size == 0 %}
        {% assign default_cats = "Magnetic Wooden STEM Toys,teal,14 pieces · the hero collection,/collections/magnetic-wooden-stem-toys|Phone Book Covers,yellow,A parent tool in disguise,/collections/phone-book-covers|Kids Clothing,coral,Soft honest made-to-last,/collections/kids-clothing" | split: "|" %}
        {% for dc in default_cats %}
          {% assign p = dc | split: "," %}
          <a href="{{ p[3] }}"
             class="ofst-cat__card {% if forloop.first %}ofst-cat__card--wide{% endif %}"
             style="background:{% if p[1] == 'teal' %}#CDE6ED{% elsif p[1] == 'yellow' %}#FFE9B8{% else %}#FFD8D8{% endif %}">
            <div class="ofst-cat__content">
              <h3 class="ofst-cat__title">{{ p[0] }}</h3>
              <p class="ofst-cat__sub">{{ p[2] }}</p>
              <span class="ofst-cat__cta">Shop collection →</span>
            </div>
          </a>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<style>
  #ofst-cat-{{ section.id }} {
    padding: 96px 0;
    background: #fff;
  }
  #ofst-cat-{{ section.id }} .ofst-cat__header { margin-bottom: 28px; }
  #ofst-cat-{{ section.id }} .ofst-cat__heading { margin-top: 10px; font-size: clamp(24px,3vw,40px); }
  /* Grid: first card is wider */
  #ofst-cat-{{ section.id }} .ofst-cat__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 20px;
  }
  #ofst-cat-{{ section.id }} .ofst-cat__card {
    position: relative;
    border-radius: var(--ofst-radius-lg);
    overflow: hidden;
    min-height: 340px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px;
    box-shadow: var(--ofst-shadow);
    transition: transform .2s ease, box-shadow .2s ease;
    text-decoration: none;
  }
  #ofst-cat-{{ section.id }} .ofst-cat__card:hover {
    transform: translateY(-2px);
    box-shadow: var(--ofst-shadow-lg);
  }
  #ofst-cat-{{ section.id }} .ofst-cat__bg-img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  #ofst-cat-{{ section.id }} .ofst-cat__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(38,70,83,.72));
  }
  #ofst-cat-{{ section.id }} .ofst-cat__content {
    position: relative;
    color: var(--ofst-deep);
  }
  #ofst-cat-{{ section.id }} .ofst-cat__content--on-img { color: #fff; }
  #ofst-cat-{{ section.id }} .ofst-cat__title {
    font-family: var(--ofst-font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -.01em;
  }
  #ofst-cat-{{ section.id }} .ofst-cat__sub { font-size: 14px; opacity: .85; margin-top: 4px; }
  #ofst-cat-{{ section.id }} .ofst-cat__cta {
    margin-top: 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    padding: 8px 14px;
    background: rgba(255,255,255,.95);
    color: var(--ofst-deep);
    border-radius: var(--ofst-pill);
  }
  #ofst-cat-{{ section.id }} .ofst-cat__content--on-img .ofst-cat__cta { background: rgba(255,255,255,.95); }

  @media (max-width: 900px) {
    #ofst-cat-{{ section.id }} .ofst-cat__grid { grid-template-columns: 1fr 1fr; }
    #ofst-cat-{{ section.id }} .ofst-cat__card--wide { grid-column: span 2; }
  }
  @media (max-width: 600px) {
    #ofst-cat-{{ section.id }} { padding: 56px 0; }
    #ofst-cat-{{ section.id }} .ofst-cat__grid { grid-template-columns: 1fr; }
    #ofst-cat-{{ section.id }} .ofst-cat__card--wide { grid-column: span 1; }
    #ofst-cat-{{ section.id }} .ofst-cat__card { min-height: 240px; }
  }
</style>

{% schema %}
{
  "name": "OFST Shop by Category",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by category 🛍️" },
    { "type": "text", "id": "heading", "label": "Heading",  "default": "Find what fits your kid today." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "limit": 3,
      "settings": [
        { "type": "text",         "id": "title",          "label": "Category title",   "default": "Magnetic Wooden STEM Toys" },
        { "type": "text",         "id": "subtitle",       "label": "Subtitle",         "default": "14 pieces · the hero collection" },
        { "type": "image_picker", "id": "image",          "label": "Background image" },
        { "type": "select",       "id": "tone",           "label": "Background tone (no image)", "options": [{"value":"teal","label":"Teal"},{"value":"yellow","label":"Yellow"},{"value":"coral","label":"Coral"}], "default": "teal" },
        { "type": "url",          "id": "collection_url", "label": "Link to collection" }
      ]
    }
  ],
  "presets": [{ "name": "OFST Shop by Category" }]
}
{% endschema %}
