{% comment %} OFST Hero Banner — Section 1 of 8 on the homepage {% endcomment %}


<section id="ofst-hero-{{ section.id }}" class="ofst-section ofst-hero" aria-label="Hero banner">
  {% comment %} Decorative background circles {% endcomment %}
  <div class="ofst-hero__blob ofst-hero__blob--top-right" aria-hidden="true"></div>
  <div class="ofst-hero__dot ofst-hero__dot--a" aria-hidden="true"></div>
  <div class="ofst-hero__dot ofst-hero__dot--b" aria-hidden="true"></div>
  <div class="ofst-hero__dot ofst-hero__dot--c" aria-hidden="true"></div>

  <div class="ofst-container ofst-hero__inner">
    {% comment %} ── Left column: copy {% endcomment %}
    <div class="ofst-hero__copy">
      {% if section.settings.badge_text != blank %}
        <span class="ofst-chip ofst-chip-yellow ofst-hero__badge">{{ section.settings.badge_text }}</span>
      {% endif %}

      <h1 class="ofst-display ofst-hero__heading">
        {{ section.settings.heading_line1 | escape }}
        {% if section.settings.heading_line2 != blank %}
          <br>
          {% assign line2       = section.settings.heading_line2 %}
          {% assign accent_word = section.settings.accent_word | default: '' %}
          {% if accent_word != blank %}
            {% assign before = line2 | split: accent_word | first %}
            {% assign after  = line2 | split: accent_word | last %}
            {{ before | escape }}<span class="ofst-hero__accent ofst-squiggle" style="color:var(--ofst-coral)">{{ accent_word | escape }}</span>{{ after | escape }}
          {% else %}
            {{ line2 | escape }}
          {% endif %}
        {% endif %}
      </h1>

      {% if section.settings.body_text != blank %}
        <p class="ofst-body ofst-hero__body">{{ section.settings.body_text | escape }}</p>
      {% endif %}

      <div class="ofst-hero__ctas">
        {% if section.settings.cta_primary_text != blank %}
          <a href="{{ section.settings.cta_primary_url | default: '/collections/all' }}" class="ofst-btn ofst-btn-cta">
            {{ section.settings.cta_primary_text | escape }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        {% endif %}
        {% if section.settings.cta_secondary_text != blank %}
          <a href="{{ section.settings.cta_secondary_url | default: pages['activities-together'].url | default: routes.root_url }}" class="ofst-btn ofst-btn-outline">
            {{ section.settings.cta_secondary_text | escape }}
          </a>
        {% endif %}
      </div>

      {% comment %} Trust badges {% endcomment %}
      <div class="ofst-hero__trust">
        <div class="ofst-hero__trust-item">
          <span class="ofst-hero__trust-icon ofst-hero__trust-icon--teal">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7h11v9H3zM14 10h4l3 3v3h-7"/><circle cx="7" cy="17" r="1.5"/><circle cx="17" cy="17" r="1.5"/></svg>
          </span>
          Free shipping $60+
        </div>
        <div class="ofst-hero__trust-item">
          <span class="ofst-hero__trust-icon ofst-hero__trust-icon--coral">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l8 3v6c0 5-4 8-8 9-4-1-8-4-8-9V6l8-3z"/><path d="M9 12l2 2 4-4"/></svg>
          </span>
          Parent-tested
        </div>
        <div class="ofst-hero__trust-item">
          <span class="ofst-hero__trust-icon ofst-hero__trust-icon--yellow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20s2-10 16-16c0 14-10 16-16 16zM4 20l8-8"/></svg>
          </span>
          Solid birch
        </div>
      </div>
    </div>

    {% comment %} ── Right column: image collage {% endcomment %}
    <div class="ofst-hero__media" aria-hidden="true">
      <div class="ofst-hero__media-main">
        {% if section.settings.image_main != blank %}
          {{ section.settings.image_main | image_url: width: 900 | image_tag: loading: 'eager', class: 'ofst-img-cover', alt: section.settings.image_main.alt | escape }}
        {% else %}
          <div class="ofst-hero__img-placeholder">[ main product image ]</div>
        {% endif %}
      </div>

      {% if section.settings.image_secondary != blank or section.settings.show_secondary_placeholder %}
        <div class="ofst-hero__media-secondary">
          {% if section.settings.image_secondary != blank %}
            {{ section.settings.image_secondary | image_url: width: 600 | image_tag: loading: 'eager', class: 'ofst-img-cover', alt: section.settings.image_secondary.alt | escape }}
          {% else %}
            <div class="ofst-hero__img-placeholder ofst-hero__img-placeholder--sm">[ secondary product image ]</div>
          {% endif %}
        </div>
      {% endif %}

      {% comment %} Floating testimonial card {% endcomment %}
      {% if section.settings.testimonial_quote != blank %}
        <div class="ofst-hero__testimonial">
          <div class="ofst-hero__stars" aria-label="5 stars">
            {% for i in (1..5) %}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="#FFB629" stroke="none" aria-hidden="true"><path d="M12 3l2.6 5.5 6 .6-4.5 4 1.3 6L12 16l-5.4 3.1 1.3-6-4.5-4 6-.6z"/></svg>
            {% endfor %}
          </div>
          <p class="ofst-hero__testimonial-quote">{{ section.settings.testimonial_quote | escape }}</p>
          {% if section.settings.testimonial_author != blank %}
            <p class="ofst-hero__testimonial-author">— {{ section.settings.testimonial_author | escape }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% comment %} Decorative dot cluster {% endcomment %}
      <div class="ofst-hero__dots" aria-hidden="true">
        <span class="ofst-hero__dot-sm" style="background:var(--ofst-coral)"></span>
        <span class="ofst-hero__dot-sm" style="background:var(--ofst-yellow)"></span>
        <span class="ofst-hero__dot-sm" style="background:var(--ofst-teal)"></span>
      </div>
    </div>
  </div>
</section>

<style>
  #ofst-hero-{{ section.id }} {
    background: #fff;
    padding: 72px 0 80px;
    position: relative;
    overflow: hidden;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 64px;
    align-items: center;
  }
  /* Decorative background blob */
  #ofst-hero-{{ section.id }} .ofst-hero__blob--top-right {
    position: absolute;
    top: -80px; right: -80px;
    width: 320px; height: 320px;
    border-radius: 50%;
    background: rgba(255,204,92,.18);
    pointer-events: none;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__dot {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__dot--a { top: 60px;  left: 40px;  width: 18px; height: 18px; background: var(--ofst-yellow); }
  #ofst-hero-{{ section.id }} .ofst-hero__dot--b { top: 200px; left: 120px; width: 10px; height: 10px; background: var(--ofst-coral); }
  #ofst-hero-{{ section.id }} .ofst-hero__dot--c { bottom: 80px; left: 40px; width: 14px; height: 14px; background: var(--ofst-teal); }
  /* Badge */
  #ofst-hero-{{ section.id }} .ofst-hero__badge { margin-bottom: 24px; display: inline-flex; }
  /* Heading */
  #ofst-hero-{{ section.id }} .ofst-hero__heading {
    font-size: clamp(44px, 5.5vw, 78px);
    line-height: 1.0;
    max-width: 640px;
    color: #000;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__accent { color: var(--ofst-coral); }
  /* Body */
  #ofst-hero-{{ section.id }} .ofst-hero__body {
    margin-top: 28px;
    max-width: 500px;
    font-size: 18px;
    font-weight: 500;
    color: #000;
  }
  /* CTAs */
  #ofst-hero-{{ section.id }} .ofst-hero__ctas {
    margin-top: 30px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  /* Trust badges */
  #ofst-hero-{{ section.id }} .ofst-hero__trust {
    margin-top: 40px;
    display: flex;
    gap: 28px;
    align-items: center;
    font-size: 14px;
    color: #000;
    font-weight: 600;
    flex-wrap: wrap;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__trust-icon {
    width: 34px; height: 34px;
    border-radius: 17px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__trust-icon--teal   { background: var(--ofst-teal); }
  #ofst-hero-{{ section.id }} .ofst-hero__trust-icon--coral  { background: var(--ofst-coral); }
  #ofst-hero-{{ section.id }} .ofst-hero__trust-icon--yellow { background: var(--ofst-yellow); }
  /* Media collage */
  #ofst-hero-{{ section.id }} .ofst-hero__media {
    position: relative;
    height: 520px;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__media-main {
    position: absolute;
    top: 0; right: 0;
    width: 78%; height: 82%;
    border-radius: var(--ofst-radius-lg);
    overflow: hidden;
    box-shadow: var(--ofst-shadow-lg);
  }
  #ofst-hero-{{ section.id }} .ofst-hero__media-secondary {
    position: absolute;
    bottom: 0; left: 0;
    width: 58%; height: 52%;
    border-radius: var(--ofst-radius-lg);
    overflow: hidden;
    box-shadow: var(--ofst-shadow-lg);
    border: 6px solid var(--ofst-base);
  }
  #ofst-hero-{{ section.id }} .ofst-hero__img-placeholder {
    width: 100%; height: 100%;
    background: #EFE7DB;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: ui-monospace, monospace;
    font-size: 11px;
    color: var(--ofst-mid);
    text-align: center;
    padding: 12px;
  }
  /* Floating testimonial */
  #ofst-hero-{{ section.id }} .ofst-hero__testimonial {
    position: absolute;
    top: 30px; left: -10px;
    background: #fff;
    border-radius: 14px;
    padding: 14px 18px;
    box-shadow: var(--ofst-shadow-lg);
    max-width: 240px;
    font-size: 13px;
    line-height: 1.5;
    z-index: 2;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__stars {
    display: flex;
    gap: 2px;
    margin-bottom: 6px;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__testimonial-quote {
    color: var(--ofst-deep);
    font-weight: 500;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__testimonial-author {
    margin-top: 6px;
    font-size: 11px;
    color: var(--ofst-mid);
  }
  /* Dot cluster */
  #ofst-hero-{{ section.id }} .ofst-hero__dots {
    position: absolute;
    bottom: -10px; right: 90px;
    display: flex;
    gap: 4px;
  }
  #ofst-hero-{{ section.id }} .ofst-hero__dot-sm {
    width: 10px; height: 10px;
    border-radius: 5px;
    display: inline-block;
  }

  /* Mobile */
  @media (max-width: 900px) {
    #ofst-hero-{{ section.id }} .ofst-hero__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    #ofst-hero-{{ section.id }} .ofst-hero__media { height: 360px; }
    #ofst-hero-{{ section.id }} { padding: 40px 0 56px; }
    #ofst-hero-{{ section.id }} .ofst-hero__testimonial { display: none; }
  }
</style>

{% schema %}
{
  "name": "OFST Hero Banner",
  "settings": [
    { "type": "text",  "id": "badge_text",          "label": "Badge text",             "default": "🌱 New · Magnetic Gear Wall just landed" },
    { "type": "text",  "id": "heading_line1",        "label": "Heading — line 1",       "default": "Hey fellow warrior —" },
    { "type": "text",  "id": "heading_line2",        "label": "Heading — line 2",       "default": "let's play together today." },
    { "type": "text",  "id": "accent_word",          "label": "Coral accent word",      "default": "together" },
    { "type": "textarea","id": "body_text",          "label": "Body copy",              "default": "Magnetic wooden STEM toys, bedtime stories, and honest play ideas from parents figuring this out right alongside you. One real moment at a time." },
    { "type": "text",  "id": "cta_primary_text",     "label": "Primary CTA label",      "default": "Shop magnetic toys" },
    { "type": "url",   "id": "cta_primary_url",      "label": "Primary CTA link" },
    { "type": "text",  "id": "cta_secondary_text",   "label": "Secondary CTA label",    "default": "Explore activities" },
    { "type": "url",   "id": "cta_secondary_url",    "label": "Secondary CTA link" },
    { "type": "header","content": "Media" },
    { "type": "image_picker", "id": "image_main",    "label": "Main hero image" },
    { "type": "image_picker", "id": "image_secondary","label": "Secondary image (bottom-left collage)" },
    { "type": "checkbox","id": "show_secondary_placeholder","label": "Show secondary image slot","default": true },
    { "type": "header","content": "Floating testimonial" },
    { "type": "textarea","id": "testimonial_quote",  "label": "Quote",                  "default": "\"My two-year-old played with the gear wall for 45 minutes. 45 minutes. Unheard of.\"" },
    { "type": "text",  "id": "testimonial_author",   "label": "Author",                 "default": "Jamie, dad of two" }
  ],
  "presets": [{ "name": "OFST Hero Banner" }]
}
{% endschema %}
