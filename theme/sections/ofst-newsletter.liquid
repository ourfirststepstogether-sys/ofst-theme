{% comment %} OFST Newsletter — Section 7 of 8 on the homepage {% endcomment %}


<section id="ofst-nl-{{ section.id }}" class="ofst-section ofst-newsletter">
  <div class="ofst-container">
    <div class="ofst-nl__card">
      {% comment %} Decorative blobs {% endcomment %}
      <div class="ofst-nl__blob ofst-nl__blob--tl" aria-hidden="true"></div>
      <div class="ofst-nl__blob ofst-nl__blob--br" aria-hidden="true"></div>

      <div class="ofst-nl__content">
        <svg class="ofst-nl__icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--ofst-deep)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="6" width="18" height="13" rx="2"/>
          <path d="M3 7l9 7 9-7"/>
        </svg>

        <h2 class="ofst-h1 ofst-nl__heading">{{ section.settings.heading | default: 'Join the Journey' | escape }}</h2>
        <p class="ofst-body ofst-nl__body">{{ section.settings.body_text | default: 'Weekly meal ideas, new toy releases, play guides, and occasional discount codes — straight to your inbox. Unsubscribe whenever. No judgment.' | escape }}</p>

        {% form 'customer', id: "ofst-nl-form-{{ section.id }}", class: 'ofst-nl__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="ofst-nl__input-row">
            <input
              type="email"
              name="contact[email]"
              id="ofst-nl-email-{{ section.id }}"
              placeholder="{{ section.settings.placeholder | default: 'your@inbox.com' }}"
              class="ofst-nl__email-input"
              required
              autocomplete="email"
              aria-label="Email address">
            <button type="submit" class="ofst-btn ofst-btn-cta" style="min-height:44px">
              {{ section.settings.submit_text | default: 'Count me in' | escape }}
            </button>
          </div>
          {% if form.errors %}
            <p class="ofst-nl__error" role="alert">{{ form.errors | default_errors }}</p>
          {% endif %}
          {% if form.posted_successfully? %}
            <p class="ofst-nl__success" role="status">You're in! Welcome to the journey 🎉</p>
          {% endif %}
        {% endform %}

        <p class="ofst-nl__fine">{{ section.settings.fine_print | default: '~1 email a week. Pinky promise.' | escape }}</p>
      </div>
    </div>
  </div>
</section>

<style>
  #ofst-nl-{{ section.id }} {
    padding: 96px 0;
    background: #fff;
  }
  #ofst-nl-{{ section.id }} .ofst-nl__card {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    background: #FFF3D1;
    padding: 64px 48px;
    border-radius: var(--ofst-radius-lg);
    position: relative;
    overflow: hidden;
  }
  /* Blobs */
  #ofst-nl-{{ section.id }} .ofst-nl__blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    opacity: .25;
  }
  #ofst-nl-{{ section.id }} .ofst-nl__blob--tl { top: -30px; left: -30px; width: 100px; height: 100px; background: var(--ofst-coral); }
  #ofst-nl-{{ section.id }} .ofst-nl__blob--br { bottom: -40px; right: -40px; width: 140px; height: 140px; background: var(--ofst-teal); opacity: .3; }
  /* Content */
  #ofst-nl-{{ section.id }} .ofst-nl__content { position: relative; }
  #ofst-nl-{{ section.id }} .ofst-nl__icon { display: block; margin: 0 auto; }
  #ofst-nl-{{ section.id }} .ofst-nl__heading { font-size: clamp(24px,3vw,36px); margin-top: 12px; }
  #ofst-nl-{{ section.id }} .ofst-nl__body    { margin-top: 10px; max-width: 540px; margin-left: auto; margin-right: auto; color: var(--ofst-mid); }
  /* Form */
  #ofst-nl-{{ section.id }} .ofst-nl__form { margin-top: 28px; }
  #ofst-nl-{{ section.id }} .ofst-nl__input-row {
    display: flex;
    gap: 8px;
    max-width: 480px;
    margin: 0 auto;
    background: #fff;
    padding: 6px;
    border-radius: var(--ofst-pill);
    box-shadow: var(--ofst-shadow);
  }
  #ofst-nl-{{ section.id }} .ofst-nl__email-input {
    flex: 1;
    border: none;
    outline: none;
    padding: 0 16px;
    font-family: var(--ofst-font-body);
    font-size: 15px;
    background: transparent;
    color: #000;
    min-width: 0;
  }
  #ofst-nl-{{ section.id }} .ofst-nl__fine  { margin-top: 14px; font-size: 12px; color: var(--ofst-mid); }
  #ofst-nl-{{ section.id }} .ofst-nl__error { margin-top: 10px; font-size: 14px; color: var(--ofst-coral); font-weight: 600; }
  #ofst-nl-{{ section.id }} .ofst-nl__success { margin-top: 10px; font-size: 14px; color: #2e7d32; font-weight: 600; }

  @media (max-width: 600px) {
    #ofst-nl-{{ section.id }} { padding: 56px 0; }
    #ofst-nl-{{ section.id }} .ofst-nl__card { padding: 40px 24px; }
    #ofst-nl-{{ section.id }} .ofst-nl__input-row { flex-direction: column; border-radius: var(--ofst-radius); }
    #ofst-nl-{{ section.id }} .ofst-nl__email-input { padding: 14px 16px; }
  }
</style>

{% schema %}
{
  "name": "OFST Newsletter",
  "settings": [
    { "type": "text",     "id": "heading",     "label": "Heading",     "default": "Join the Journey" },
    { "type": "textarea", "id": "body_text",   "label": "Body copy",   "default": "Weekly meal ideas, new toy releases, play guides, and occasional discount codes — straight to your inbox. Unsubscribe whenever. No judgment." },
    { "type": "text",     "id": "placeholder", "label": "Input placeholder", "default": "your@inbox.com" },
    { "type": "text",     "id": "submit_text", "label": "Button text", "default": "Count me in" },
    { "type": "text",     "id": "fine_print",  "label": "Fine print",  "default": "~1 email a week. Pinky promise." }
  ],
  "presets": [{ "name": "OFST Newsletter" }]
}
{% endschema %}
