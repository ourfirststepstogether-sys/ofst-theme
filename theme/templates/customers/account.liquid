<section class="ofst-section">
  <div class="ofst-container">
    <h1 class="ofst-h1">{{ 'customer.account.title' | t }}</h1>
    <p><a href="{{ routes.account_logout_url }}" class="ofst-link">Log out</a></p>

    <div class="ofst-account">
      <aside>
        <h2 class="ofst-h3">{{ 'customer.account.details' | t }}</h2>
        <p>{{ customer.default_address | format_address }}</p>
        <p><a href="{{ routes.account_addresses_url }}" class="ofst-link">{{ 'customer.account.view_addresses' | t }}</a></p>
      </aside>

      <div>
        <h2 class="ofst-h3">{{ 'customer.orders.title' | t }}</h2>
        {% if customer.orders.size > 0 %}
          <table class="ofst-orders">
            <thead>
              <tr>
                <th>{{ 'customer.orders.order_number' | t }}</th>
                <th>{{ 'customer.orders.date' | t }}</th>
                <th>{{ 'customer.orders.payment_status' | t }}</th>
                <th>{{ 'customer.orders.fulfillment_status' | t }}</th>
                <th>{{ 'customer.orders.total' | t }}</th>
              </tr>
            </thead>
            <tbody>
              {% for order in customer.orders %}
                <tr>
                  <td><a href="{{ order.customer_url }}" class="ofst-link">{{ order.name }}</a></td>
                  <td>{{ order.created_at | date: "%B %d, %Y" }}</td>
                  <td>{{ order.financial_status_label }}</td>
                  <td>{{ order.fulfillment_status_label }}</td>
                  <td>{{ order.total_price | money }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        {% else %}
          <p>{{ 'customer.orders.none' | t }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>
<style>
  .ofst-account { display: grid; grid-template-columns: 260px 1fr; gap: 40px; margin-top: 24px; }
  .ofst-orders { width: 100%; border-collapse: collapse; }
  .ofst-orders th, .ofst-orders td { text-align: left; padding: 10px 8px; border-bottom: 1px solid var(--ofst-base); }
  @media (max-width: 700px) { .ofst-account { grid-template-columns: 1fr; } }
</style>
