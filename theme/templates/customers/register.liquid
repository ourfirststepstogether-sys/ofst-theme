<section class="ofst-section">
  <div class="ofst-container ofst-customer">
    <h1 class="ofst-h1">{{ 'customer.register.title' | t }}</h1>

    {% form 'create_customer', novalidate: 'novalidate' %}
      {{ form.errors | default_errors }}
      <label for="FirstName">{{ 'customer.register.first_name' | t }}</label>
      <input type="text" name="customer[first_name]" id="FirstName" autocomplete="given-name">

      <label for="LastName">{{ 'customer.register.last_name' | t }}</label>
      <input type="text" name="customer[last_name]" id="LastName" autocomplete="family-name">

      <label for="Email">{{ 'customer.register.email' | t }}</label>
      <input type="email" name="customer[email]" id="Email" autocomplete="email" required>

      <label for="Password">{{ 'customer.register.password' | t }}</label>
      <input type="password" name="customer[password]" id="Password" autocomplete="new-password" required>

      <button type="submit" class="ofst-btn ofst-btn-cta">{{ 'customer.register.submit' | t }}</button>
    {% endform %}
  </div>
</section>
<style>
  .ofst-customer { max-width: 480px; padding: 48px 20px; }
  .ofst-customer label { display: block; margin: 16px 0 4px; font-family: var(--ofst-font-display); font-weight: 600; }
  .ofst-customer input { width: 100%; padding: 10px 14px; border: 2px solid var(--ofst-ink); border-radius: 10px; font-family: var(--ofst-font-body); }
</style>
