<section class="ofst-section">
  <div class="ofst-container ofst-customer">
    <h1 class="ofst-h1">{{ 'customer.login.title' | t }}</h1>

    {% form 'customer_login', novalidate: 'novalidate' %}
      {{ form.errors | default_errors }}
      <label for="CustomerEmail">{{ 'customer.login.email' | t }}</label>
      <input type="email" name="customer[email]" id="CustomerEmail" autocomplete="email" required>

      {% if form.password_needed %}
        <label for="CustomerPassword">{{ 'customer.login.password' | t }}</label>
        <input type="password" name="customer[password]" id="CustomerPassword" autocomplete="current-password" required>
      {% endif %}

      <button type="submit" class="ofst-btn ofst-btn-cta">{{ 'customer.login.sign_in' | t }}</button>
    {% endform %}

    <p class="ofst-muted">
      <a href="#recover" class="ofst-link" onclick="document.getElementById('recover').hidden=false;document.getElementById('login-links').hidden=true;return false;">{{ 'customer.login.forgot_password' | t }}</a>
      &nbsp;·&nbsp;
      <a href="{{ routes.account_register_url }}" class="ofst-link">{{ 'customer.login.create_account' | t }}</a>
    </p>

    <div id="recover" hidden>
      <h2 class="ofst-h2">{{ 'customer.recover_password.title' | t }}</h2>
      <p>{{ 'customer.recover_password.subtext' | t }}</p>
      {% form 'recover_customer_password' %}
        {% if form.posted_successfully? %}<p class="ofst-success">{{ 'customer.recover_password.success' | t }}</p>{% endif %}
        {{ form.errors | default_errors }}
        <label for="RecoverEmail">{{ 'customer.recover_password.email' | t }}</label>
        <input type="email" name="email" id="RecoverEmail" required>
        <button type="submit" class="ofst-btn ofst-btn-cta">{{ 'customer.recover_password.submit' | t }}</button>
      {% endform %}
    </div>
  </div>
</section>
<style>
  .ofst-customer { max-width: 480px; padding: 48px 20px; }
  .ofst-customer label { display: block; margin: 16px 0 4px; font-family: var(--ofst-font-display); font-weight: 600; }
  .ofst-customer input { width: 100%; padding: 10px 14px; border: 2px solid var(--ofst-ink); border-radius: 10px; font-family: var(--ofst-font-body); }
  .ofst-customer button { margin-top: 20px; }
</style>
