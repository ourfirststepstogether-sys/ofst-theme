<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | money, shop: shop.name }}</title>
    {% render 'ofst-fonts' %}
    {{ 'ofst-theme.css' | asset_url | stylesheet_tag }}
    <style>
      body { background: var(--ofst-bg); font-family: var(--ofst-font-body); margin: 0; padding: 48px 24px; }
      .wrap { max-width: 560px; margin: 0 auto; text-align: center; }
      .card { background: #FFF3D1; border: 1px solid var(--ofst-ink); border-radius: 18px; padding: 32px; margin: 24px 0; }
      .value { font-family: var(--ofst-font-display); font-size: 3rem; font-weight: 700; color: var(--ofst-coral); }
      .code { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 1.25rem; letter-spacing: 1px; padding: 12px 16px; background: #fff; border: 1px dashed var(--ofst-ink); border-radius: 12px; display: inline-block; margin-top: 12px; }
      .btn { display: inline-block; background: var(--ofst-coral); color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; margin-top: 16px; }
      @media print { .noprint { display: none; } }
    </style>
  </head>
  <body>
    <div class="wrap">
      <h1 class="ofst-h1">A gift from {{ shop.name }}</h1>
      <div class="card">
        <div class="value">{{ gift_card.initial_value | money }}</div>
        {% unless gift_card.enabled %}<p><strong>This card has been disabled.</strong></p>{% endunless %}
        {% if gift_card.expired %}<p><strong>This card has expired.</strong></p>{% endif %}
        <p>Balance: {{ gift_card.balance | money }}</p>
        <div class="code" id="gc-code">{{ gift_card.code | format_code }}</div>
        <p>Use this code at checkout to redeem your gift card.</p>
        <a href="{{ shop.url }}" class="btn">Shop now</a>
      </div>
      <p class="noprint"><button onclick="window.print()" class="btn">Print this page</button></p>
    </div>
  </body>
</html>
