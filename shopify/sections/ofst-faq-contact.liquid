{% comment %} OFST FAQ + Contact section {% endcomment %}

<link rel="stylesheet" href="{{ 'ofst-theme.css' | asset_url }}">

<section id="ofst-faq-{{ section.id }}" class="ofst-section ofst-faq">
  <div class="ofst-container">
    <div class="ofst-faq__intro">
      <span class="ofst-eyebrow">{{ section.settings.eyebrow | default: 'FAQ & Contact' }}</span>
      <h1 class="ofst-display ofst-faq__heading">{{ section.settings.heading | default: 'Questions? Fire away.' | escape }}</h1>
      <p class="ofst-body ofst-faq__sub">{{ section.settings.subtext | default: "The most common ones below. If yours isn't here, the contact form goes to a real inbox a real human reads." | escape }}</p>
    </div>

    <div class="ofst-faq__layout">
      {% comment %} FAQ accordion {% endcomment %}
      <div class="ofst-faq__qs">
        {% for block in section.blocks %}
          <details class="ofst-faq__item" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
            <summary class="ofst-faq__q">
              {{ block.settings.question | escape }}
              <svg class="ofst-faq__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="ofst-faq__a">{{ block.settings.answer | escape }}</p>
          </details>
        {% endfor %}

        {% comment %} Fallback questions {% endcomment %}
        {% if section.blocks.size == 0 %}
          {% assign faq_items = "Are the magnets safe if my toddler mouths them?,Yes. Every magnet is sealed inside wood and glue-locked. We test-pull every piece to a 22-pound standard. None are removable or loose.|What ages is the gear wall really for?,Honestly 2 is the sweet spot and it keeps being useful until around 7. Under 18 months we'd say not yet.|How long does shipping take?,Most US orders ship within 2 business days. Free over $60. We'll email you when it leaves Michigan.|What if something breaks?,Write us. We send replacement pieces free forever. Email care@ofst.co and a real person named Jordan or Maya will answer.|Is the wood actually sustainable?,We source birch from FSC-certified mills in Wisconsin. Our finish is EWG-rated 1 water-based food-safe.|Do you do wholesale / preschools?,Yes. Email wholesale@ofst.co and we'll set you up with the educator discount." | split: "|" %}
          {% assign faq_count = faq_items.size %}
          {% for i in (0..100) %}
            {% assign q_idx = i | times: 2 %}
            {% assign a_idx = q_idx | plus: 1 %}
            {% if q_idx < faq_count %}
              <details class="ofst-faq__item" {% if i == 0 %}open{% endif %}>
                <summary class="ofst-faq__q">
                  {{ faq_items[q_idx] }}
                  <svg class="ofst-faq__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                </summary>
                <p class="ofst-faq__a">{{ faq_items[a_idx] }}</p>
              </details>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>

      {% comment %} Contact sidebar {% endcomment %}
      <aside class="ofst-faq__contact">
        <h3 class="ofst-faq__contact-title">{{ section.settings.contact_title | default: 'Write a real person' | escape }}</h3>
        <p class="ofst-faq__contact-sub">{{ section.settings.contact_sub | default: 'Jordan and Maya split the inbox. We answer within 24 hours on weekdays, usually sooner.' | escape }}</p>

        <div class="ofst-faq__contact-emails">
          <div>{{ section.settings.email_care | default: 'care@ofst.co' | escape }}</div>
          <div>{{ section.settings.email_wholesale | default: 'wholesale@ofst.co' | escape }}</div>
          <div>{{ section.settings.email_press | default: 'press@ofst.co' | escape }}</div>
        </div>

        {% form 'contact', id: "ofst-contact-{{ section.id }}", class: 'ofst-faq__contact-form' %}
          {% if form.posted_successfully? %}
            <p class="ofst-faq__contact-success">Message sent! We'll get back to you soon 🎉</p>
          {% else %}
            {% if form.errors %}
              {{ form.errors | default_errors }}
            {% endif %}
            <input type="text" name="contact[name]" placeholder="Your name" required class="ofst-faq__contact-input" autocomplete="name">
            <input type="email" name="contact[email]" placeholder="Email" required class="ofst-faq__contact-input" autocomplete="email">
            <textarea name="contact[body]" rows="4" placeholder="What's up?" class="ofst-faq__contact-textarea"></textarea>
            <button type="submit" class="ofst-btn ofst-btn-cta">Send note</button>
          {% endif %}
        {% endform %}
      </aside>
    </div>
  </div>
</section>

<style>
  #ofst-faq-{{ section.id }} {
    padding: 56px 0 64px;
    background: var(--ofst-base);
  }
  #ofst-faq-{{ section.id }} .ofst-faq__intro { max-width: 1000px; margin: 0 auto 40px; }
  #ofst-faq-{{ section.id }} .ofst-faq__heading { font-size: clamp(32px,4vw,48px); margin-top: 8px; }
  #ofst-faq-{{ section.id }} .ofst-faq__sub { margin-top: 12px; color: var(--ofst-mid); max-width: 560px; }
  /* Layout */
  #ofst-faq-{{ section.id }} .ofst-faq__layout {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 48px;
    max-width: 1000px;
    margin: 0 auto;
  }
  /* FAQ items */
  #ofst-faq-{{ section.id }} .ofst-faq__item {
    background: #fff;
    border-radius: var(--ofst-radius);
    padding: 16px 20px;
    box-shadow: var(--ofst-shadow);
    margin-bottom: 10px;
  }
  #ofst-faq-{{ section.id }} .ofst-faq__q {
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    font-family: var(--ofst-font-body);
    color: #000;
  }
  #ofst-faq-{{ section.id }} .ofst-faq__q::-webkit-details-marker { display: none; }
  #ofst-faq-{{ section.id }} .ofst-faq__chevron { flex-shrink: 0; transition: transform .2s; color: var(--ofst-mid); }
  #ofst-faq-{{ section.id }} .ofst-faq__item[open] .ofst-faq__chevron { transform: rotate(180deg); }
  #ofst-faq-{{ section.id }} .ofst-faq__a { margin-top: 10px; font-size: 15px; color: var(--ofst-mid); line-height: 1.65; font-family: var(--ofst-font-body); }
  /* Contact sidebar */
  #ofst-faq-{{ section.id }} .ofst-faq__contact {
    background: var(--ofst-deep);
    color: #fff;
    border-radius: var(--ofst-radius);
    padding: 28px;
    align-self: flex-start;
  }
  #ofst-faq-{{ section.id }} .ofst-faq__contact-title { font-family: var(--ofst-font-display); font-size: 22px; font-weight: 700; color: #fff; }
  #ofst-faq-{{ section.id }} .ofst-faq__contact-sub { font-size: 14px; color: rgba(255,255,255,.75); margin-top: 8px; line-height: 1.6; font-family: var(--ofst-font-body); }
  #ofst-faq-{{ section.id }} .ofst-faq__contact-emails { margin-top: 18px; display: grid; gap: 10px; font-size: 14px; font-family: var(--ofst-font-body); color: rgba(255,255,255,.9); }
  #ofst-faq-{{ section.id }} .ofst-faq__contact-form { margin-top: 22px; display: grid; gap: 10px; }
  #ofst-faq-{{ section.id }} .ofst-faq__contact-input,
  #ofst-faq-{{ section.id }} .ofst-faq__contact-textarea {
    padding: 12px 14px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,.2);
    background: rgba(255,255,255,.08);
    color: #fff;
    font-size: 14px;
    font-family: var(--ofst-font-body);
    resize: none;
    width: 100%;
  }
  #ofst-faq-{{ section.id }} .ofst-faq__contact-input::placeholder,
  #ofst-faq-{{ section.id }} .ofst-faq__contact-textarea::placeholder { color: rgba(255,255,255,.4); }
  #ofst-faq-{{ section.id }} .ofst-faq__contact-success { color: var(--ofst-yellow); font-weight: 600; font-family: var(--ofst-font-body); font-size: 15px; }

  @media (max-width: 900px) {
    #ofst-faq-{{ section.id }} .ofst-faq__layout { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "OFST FAQ & Contact",
  "settings": [
    { "type": "text",     "id": "eyebrow",         "label": "Eyebrow",         "default": "FAQ & Contact" },
    { "type": "text",     "id": "heading",          "label": "Heading",         "default": "Questions? Fire away." },
    { "type": "textarea", "id": "subtext",          "label": "Subtext",         "default": "The most common ones below. If yours isn't here, the contact form goes to a real inbox a real human reads." },
    { "type": "header",   "label": "Contact sidebar" },
    { "type": "text",     "id": "contact_title",    "label": "Title",           "default": "Write a real person" },
    { "type": "textarea", "id": "contact_sub",      "label": "Subtitle",        "default": "Jordan and Maya split the inbox. We answer within 24 hours on weekdays, usually sooner." },
    { "type": "text",     "id": "email_care",       "label": "Care email",      "default": "care@ofst.co" },
    { "type": "text",     "id": "email_wholesale",  "label": "Wholesale email", "default": "wholesale@ofst.co" },
    { "type": "text",     "id": "email_press",      "label": "Press email",     "default": "press@ofst.co" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text",     "id": "question", "label": "Question", "default": "Are the magnets safe if my toddler mouths them?" },
        { "type": "textarea", "id": "answer",   "label": "Answer",   "default": "Yes. Every magnet is sealed inside wood and glue-locked. We test-pull every piece to a 22-pound standard. None are removable or loose." }
      ]
    }
  ],
  "presets": [{ "name": "OFST FAQ & Contact" }]
}
{% endschema %}
